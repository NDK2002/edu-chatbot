GEMINI_API_KEY=

# Server-side only (Next.js → FastAPI, không expose ra browser)
BACKEND_URL=http://backend:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI MODELS ──────────────────────────────
AI_MODEL_URL=https://ai-model.ndk.id.vn
AI_MODEL_API_KEY=

# ── EMBED MODEL ──────────────────────────────
EMBED_MODEL=AITeamVN/Vietnamese_Embedding
EMBED_URL=${AI_MODEL_URL}/embeddings

# ── RERANK MODEL ──────────────────────────────
RERANK_MODEL=BAAI/bge-reranker-v2-m3    
RERANK_URL=${AI_MODEL_URL}/rerank

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_MATH=edu_math_canh_dieu
QDRANT_COLLECTION_DICT_VI_TAY=edu_vi_tay_nung_dictionary
QDRANT_COLLECTION_DICT_TAY_VI=edu_tay_vi_dictionary
QDRANT_COLLECTION_DICT=edu_dictionary
VECTOR_SCORE_THRESHOLD=0.45
RERANK_SCORE_THRESHOLD=0.80
QDRANT_TOP_K=40

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_CACHE_TTL=86400
REDIS_MAX_MEMORY=256mb

EMBEDDING_MODEL=AITeamVN/Vietnamese_Embedding_v2
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RERANKER_TOP_N=5

CONTENT_SAFETY_MODE=strict
GOOGLE_VISION_API_KEY=

# Supabase — lấy từ Supabase dashboard → Project Settings → API
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=         # backend only — không expose ra browser

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_PER_HOUR=10
RATE_LIMIT_PER_DAY=50
RATE_LIMIT_WHITELIST=127.0.0.1,::1

# Conversation auto-compact
COMPACT_THRESHOLD=20     # số messages trigger auto-compact
COMPACT_KEEP_LAST=5      # số messages giữ lại sau compact
